# =============================================================================
# LogiFit — Exemplo de variáveis de ambiente
#
# Copie para .env.local (nunca committar!) e preencha.
# Cada sprint vai adicionar as variáveis que precisa aqui.
# =============================================================================


# =============================================================================
# Supabase (Sprint 00)
# =============================================================================

# URL do projeto Supabase cloud (ou local supabase start → http://127.0.0.1:54321)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Chave anon — exposta ao cliente (OK; RLS protege)
SUPABASE_ANON_KEY=eyJ...

# Service role — NUNCA expor ao cliente; só server-side (Server Actions, API routes, jobs)
SUPABASE_SERVICE_ROLE=eyJ...

# Connection string para Drizzle (Transaction pooler 6543)
DATABASE_URL=postgresql://postgres.xxxxxxxx:<password>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres


# =============================================================================
# IA — LogiFit default via Vertex AI (Gemini) + Groq (STT) — ADR 0064
# =============================================================================

# Google Cloud — Vertex AI (default LogiFit para chat/embedding/classification/
# extraction/vision). Região São Paulo resolve LGPD data residency.
# https://console.cloud.google.com/vertex-ai
GOOGLE_CLOUD_PROJECT=logifit-dev
VERTEX_AI_LOCATION=southamerica-east1
# Service Account Key JSON (path ou base64) — gerar em IAM & Admin → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/logifit-vertex-sa.json

# Groq — transcrição (Whisper) embutida no plano LogiFit (Sprint 31)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# Fallback providers LogiFit (ADR 0064) — habilita quando Sprint 06 precisar
# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4.5-mini

# Chave de criptografia para BYOK do tenant (AES-256-GCM)
# gerar: openssl rand -hex 32
ENCRYPTION_KEY=xxxxxxxxxxxxx


# =============================================================================
# Observabilidade (Sprint 00)
# =============================================================================

# Sentry — https://sentry.io/settings/ → Projects → [seu projeto] → Client Keys
SENTRY_DSN=https://xxxxxxx@oXXXXX.ingest.sentry.io/xxxxxxx
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxx  # para upload de sourcemaps no build

# PostHog — https://app.posthog.com/settings/project → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Logtail (Better Stack) — https://logs.betterstack.com/team/XXXX/sources
LOGTAIL_SOURCE_TOKEN=xxxxxxxxxxxxx


# =============================================================================
# Upstash Redis — rate-limit por tenant (Sprint 06)
# =============================================================================
# https://console.upstash.com/redis
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxx


# =============================================================================
# Email (Sprint 13)
# =============================================================================

# Resend — https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=no-reply@logifit.com.br


# =============================================================================
# Pagamentos — Asaas (Sprint 04)
# =============================================================================
# Começa em sandbox: https://sandbox.asaas.com
# ASAAS_API_KEY=$aact_xxxxxxxxxxxxx
# ASAAS_ENV=sandbox  # ou 'production' quando for cobrar tenants reais
# ASAAS_WEBHOOK_SECRET=xxxxxxxxxxxxx  # para validar HMAC dos webhooks


# =============================================================================
# CNPJ Lookup (Sprint 01a) — providers abstraídos (ADR 0048)
# =============================================================================
# BrasilAPI é default e gratuito — não precisa API key
# ReceitaWS como fallback — não precisa API key (rate-limit 3 req/min)
# CNPJá! pago (opcional) — https://cnpja.com
# CNPJA_API_KEY=xxxxxxxxxxxxx


# =============================================================================
# OCR providers (Sprint 15 — ADR 0035)
# =============================================================================
# OCR.space (default) — https://ocr.space/ocrapi
# OCRSPACE_API_KEY=K8XXXXXXXXXX

# Google Vision (opcional)
# GOOGLE_VISION_API_KEY=AIzaxxxxxxxxxxxxx

# AWS Textract (opcional)
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
# AWS_REGION=sa-east-1


# =============================================================================
# NF-e providers (Sprint 17 — ADR 0038)
# =============================================================================
# Arquivei (default tier gratuito) — https://arquivei.com.br
# ARQUIVEI_API_ID=xxxxxxxxxxxxx
# ARQUIVEI_API_KEY=xxxxxxxxxxxxx

# Sieg (fallback) — https://sieg.com
# SIEG_API_KEY=xxxxxxxxxxxxx


# =============================================================================
# Fiscal — Focus NFe (Sprint 36 — ADR 0059)
# =============================================================================
# https://focusnfe.com.br
# FOCUS_NFE_TOKEN=xxxxxxxxxxxxx
# FOCUS_NFE_ENV=homologacao  # ou 'producao'


# =============================================================================
# WhatsApp (Sprint 13 — ADR 0025, provider decidido no sprint)
# =============================================================================
# Twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Z-API
# ZAPI_INSTANCE_ID=xxxxxxxxxxxxx
# ZAPI_TOKEN=xxxxxxxxxxxxx


# =============================================================================
# App config
# =============================================================================

# Base URL do app — muda em dev/preview/prod
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domínio para multi-tenant por subdomínio (ADR 0064 esperado)
# Ex: vital.logifit.com.br — middleware extrai "vital" como tenant slug
NEXT_PUBLIC_ROOT_DOMAIN=logifit.com.br

# Environment
NODE_ENV=development

# Locale default (ADR 0052)
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# Feature flags globais (override PostHog flags em dev)
# FEATURE_FLAG_<name>=true


# =============================================================================
# Segurança / secrets internos
# =============================================================================

# Secret para HMAC de QR rotativo (Sprint 08) — gerar com: openssl rand -hex 32
# QR_HMAC_SECRET=xxxxxxxxxxxxx

# Secret para assinar JWTs próprios (se houver além do Supabase)
# JWT_SECRET=xxxxxxxxxxxxx

# Encryption key para campos sensíveis (certificados A1, API keys de providers por tenant)
# ENCRYPTION_KEY=xxxxxxxxxxxxx  # 32 bytes hex — openssl rand -hex 32
