# =============================================================================
# LogiFit — Exemplo de variáveis de ambiente
#
# Copie para .env.local (nunca committar!) e preencha.
# Cada sprint adiciona as variáveis que precisa aqui.
#
# Stack: self-host total Oracle SP via Coolify (ADR 0091).
# Dev local: docker compose (Postgres + Redis + MinIO + Mailhog).
# Prod: variáveis equivalentes em Coolify env vars.
# =============================================================================


# =============================================================================
# Postgres self-hosted (Sprint 00 — ADR 0091)
# =============================================================================
# Dev: container Postgres do docker-compose.yml na raiz
# Prod: container Postgres no Coolify, mesmo VPS Oracle Vinhedo

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logifit

# PgBouncer (transaction pool) — produção plugado entre app e PG via Coolify
# Dev: aponta direto pro container PG
# DATABASE_POOL_URL=postgresql://postgres:postgres@localhost:6432/logifit


# =============================================================================
# Redis self-hosted (Sprint 00 — rate limit + cache; ADR 0091)
# =============================================================================
REDIS_URL=redis://localhost:6379


# =============================================================================
# MinIO self-hosted (Sprint 00 — Storage adapter pattern; ADR 0091)
# =============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=sa-east-1
MINIO_BUCKET_PREFIX=logifit-dev


# =============================================================================
# Auth — JWT cookie próprio (Sprint 01a — BetterAuth ou Lucia)
# =============================================================================
# Gerar: openssl rand -hex 32
AUTH_SECRET=
# AUTH_TRUST_HOST=true  # produção atrás do Caddy/Coolify


# =============================================================================
# IA — LogiFit default via Vertex AI (Gemini) + Groq (STT) — ADR 0064
# =============================================================================

# Google Cloud — Vertex AI (default LogiFit). Região São Paulo resolve LGPD residency.
# https://console.cloud.google.com/vertex-ai
GOOGLE_CLOUD_PROJECT=logifit-dev
VERTEX_AI_LOCATION=southamerica-east1
# Service Account Key JSON (path) — gerar em IAM & Admin → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/logifit-vertex-sa.json

# Groq — transcrição (Whisper) embutida no plano LogiFit (Sprint 31)
# https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# Fallback providers BYOK (ADR 0064)
# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Encryption key para BYOK do tenant (AES-256-GCM)
# gerar: openssl rand -hex 32
ENCRYPTION_KEY=


# =============================================================================
# Observabilidade self-hosted (Sprint 00 — ADR 0091)
# =============================================================================

# GlitchTip self-hosted (Sentry-API-compatível) — container Coolify
# Dev: opcional, container Compose; Prod: subdomínio errors.logifit.com.br
GLITCHTIP_DSN=
SENTRY_AUTH_TOKEN=  # pra upload de sourcemaps no build (compatibilidade @sentry/nextjs)

# Loki + Grafana self-hosted — pino → stdout → Promtail → Loki
# Dev: opcional; Prod: subdomínio monitor.logifit.com.br
LOKI_URL=http://localhost:3100


# =============================================================================
# Email transacional — AWS SES (ADR 0091; única dependência paga core)
# =============================================================================
# Sandbox SES até pedir production access; antes disso só envia pra emails verificados
AWS_SES_REGION=sa-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
EMAIL_FROM=no-reply@logifit.com.br

# Dev local: Mailhog captura emails sem mandar (acessar UI em http://localhost:8025)
# Quando NODE_ENV=development e SMTP_HOST/PORT setados, app usa SMTP local em vez de SES
SMTP_HOST=localhost
SMTP_PORT=1025


# =============================================================================
# Pagamentos — Asaas (Sprint 04)
# =============================================================================
# Sandbox: https://sandbox.asaas.com
# ASAAS_API_KEY=$aact_xxxxxxxxxxxxx
# ASAAS_ENV=sandbox  # ou 'production' quando for cobrar tenants reais
# ASAAS_WEBHOOK_SECRET=xxxxxxxxxxxxx  # pra validar HMAC


# =============================================================================
# CNPJ Lookup (Sprint 01a — ADR 0048)
# =============================================================================
# BrasilAPI default e gratuito — sem API key
# ReceitaWS fallback — sem API key (rate-limit 3 req/min)
# CNPJá! pago opcional — https://cnpja.com
# CNPJA_API_KEY=xxxxxxxxxxxxx


# =============================================================================
# OCR providers (Sprint 15 — ADR 0035)
# =============================================================================
# OCR.space default — https://ocr.space/ocrapi
# OCRSPACE_API_KEY=K8XXXXXXXXXX

# Google Vision (opcional)
# GOOGLE_VISION_API_KEY=AIzaxxxxxxxxxxxxx


# =============================================================================
# NF-e providers (Sprint 17 — ADR 0038)
# =============================================================================
# Arquivei (default tier gratuito) — https://arquivei.com.br
# ARQUIVEI_API_ID=xxxxxxxxxxxxx
# ARQUIVEI_API_KEY=xxxxxxxxxxxxx


# =============================================================================
# Fiscal — Focus NFe (Sprint 36 — ADR 0059)
# =============================================================================
# https://focusnfe.com.br
# FOCUS_NFE_TOKEN=xxxxxxxxxxxxx
# FOCUS_NFE_ENV=homologacao  # ou 'producao'


# =============================================================================
# WhatsApp BSP (Sprint 13 — ADR 0025)
# =============================================================================
# Twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Gupshup BR (alternativa)
# GUPSHUP_API_KEY=xxxxxxxxxxxxx
# GUPSHUP_APP_ID=xxxxxxxxxxxxx


# =============================================================================
# Cloudflare DNS + Turnstile (free)
# =============================================================================
# Turnstile — https://dash.cloudflare.com → Turnstile (Sprint 01a usa)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET=

# Cloudflare API (DNS-01 challenge pro Caddy SSL automático em prod)
# CLOUDFLARE_API_TOKEN=  # só prod (Coolify env)


# =============================================================================
# Backup off-site — Cloudflare R2 (ADR 0091, regra 40)
# =============================================================================
# Free tier 10GB + zero egress fee = DR drills sem custo durante MVP
# Configurado em prod via Coolify env + cron interno (rclone S3 API)
# Cloudflare → R2 → Manage R2 API tokens (criar com permissão Object Read & Write apenas no bucket logifit-backup)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=logifit-backup
# R2_ENDPOINT=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# BACKUP_GPG_RECIPIENT=backup@logifit.com.br  # public key importada antes


# =============================================================================
# App config
# =============================================================================

# Base URL do app — muda em dev/preview/prod
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domínio raiz multi-tenant por subdomínio (ADR 0065)
# Ex: vital.logifit.com.br — middleware extrai "vital" como tenant slug
# Dev local: 'localhost:3000' + acesso via http://{slug}.localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=logifit.com.br

# Canal LGPD do titular (ADR 0067)
PRIVACY_EMAIL=privacidade@logifit.com.br

# Fallback comercial
COMMERCIAL_EMAIL=contato@logifit.com.br

# Environment
NODE_ENV=development

# Locale default (ADR 0052)
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR


# =============================================================================
# Segurança / secrets internos
# =============================================================================

# Secret HMAC pro QR rotativo Sprint 08 — gerar: openssl rand -hex 32
# QR_HMAC_SECRET=

# JWT signing secret (BetterAuth/Lucia em Sprint 01a)
# JWT_SECRET=
