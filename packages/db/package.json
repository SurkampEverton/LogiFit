{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "description": "Database schema, migrations and RLS policies (Drizzle is the single source of truth — ADR 0004)",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./policies": "./src/policies/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:rls-check": "tsx tests/rls-check.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
